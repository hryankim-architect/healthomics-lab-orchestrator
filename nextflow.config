// nextflow.config — healthomics-lab-orchestrator
//
// Minimal config for the chr22 RNA-seq orchestration demo. Keep this file
// short: every option here either ships data into the pipeline or lets the
// substrate (audit / MLflow) hook into it. Nothing else.

manifest {
    name        = 'healthomics-lab-orchestrator'
    author      = 'H. Ryan Kim'
    description = 'RNA-seq pipeline (FastQC -> HISAT2 -> featureCounts -> MultiQC) with audit + MLflow hooks. Orchestration demo, not production.'
    version     = '0.1.0'
    nextflowVersion = '>=23.04'
}

// ---------------------------------------------------------------------------
// Process environment
// ---------------------------------------------------------------------------
// macOS chi-mac-p note (lessons L-psi, L-omega, L-alpha2):
//   - L-psi: (base) conda env exports JAVA_HOME pointing at miniconda Java 25,
//     which Nextflow 23.04 rejects ("Java 8 or later, up to 20"). The launch
//     wrapper (scripts/run_lab.sh) runs `conda deactivate` so the system Java
//     19.0.1 at /usr/bin/java is picked up.
//   - L-omega: `conda deactivate` also removes conda python from PATH, which
//     breaks the per-process substrate hooks that shell out to
//     `python -m healthomics_lab.process_hooks emit`. Project venv path
//     prepended below restores python.
//   - L-alpha2: `conda deactivate` ALSO removes the bioconda-installed tools
//     (fastqc, hisat2, samtools, featureCounts, seqkit). We explicitly add
//     ~/miniconda3/bin to PATH so those tools stay reachable even with conda
//     deactivated. ~/miniconda3/bin is placed AFTER /usr/bin so system Java 19
//     wins over miniconda Java 25 in PATH lookup.
//
// Final PATH priority per process:
//   1. ${projectDir}/.venv/bin    -> venv python + healthomics_lab package
//   2. /opt/homebrew/bin           -> brew nextflow + brew CLIs
//   3. /usr/bin                    -> system Java 19.0.1 (Nextflow-compatible)
//   4. ~/miniconda3/bin            -> bioconda tools (fastqc/hisat2/...) + conda CLI
//   5. ${System.getenv('PATH')}    -> everything else from the parent shell
env {
    PATH = "${projectDir}/.venv/bin:/opt/homebrew/bin:/usr/bin:${System.getenv('HOME')}/miniconda3/bin:${System.getenv('PATH')}"

    // Absolute-path audit ledger so per-Nextflow-process audit entries all
    // land in the same NDJSON file. Without this, each process writes to its
    // own work/<hash>/audit/local-demo.ndjson and the chain is lost when
    // Nextflow cleans the work dirs.
    HEALTHOMICS_AUDIT_LEDGER = "${projectDir}/audit/local-demo.ndjson"
}

// ---------------------------------------------------------------------------
// Pipeline parameters (override on the command line with --<name> <value>)
// ---------------------------------------------------------------------------

params {
    // Input sample sheet (CSV: sample_id,condition,fastq_1,fastq_2)
    samples       = "${projectDir}/data/samples.csv"

    // Reference inputs (chr22 subset, populated by `make data`)
    reference_fa  = "${projectDir}/data/reference/chr22.fa.gz"
    reference_gtf = "${projectDir}/data/reference/chr22.gtf.gz"
    hisat2_index  = "${projectDir}/data/reference/hisat2_index/chr22"

    // Output destinations
    results_dir   = "${projectDir}/results"
    audit_dir     = "${projectDir}/audit"

    // Substrate identifiers — the outer pipeline.py overrides job_id at launch
    job_id        = 'nextflow-local'

    // Thread budgets (kept modest so the demo runs on a laptop)
    threads_align = 4
    threads_count = 4
}

// ---------------------------------------------------------------------------
// Process defaults
// ---------------------------------------------------------------------------

process {
    // Each process publishes its outputs into results/<stage>/
    publishDir = [
        path: { "${params.results_dir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy',
        overwrite: true,
    ]

    // Conservative resource defaults; individual processes can override
    cpus   = 2
    memory = '2 GB'

    // Per-process error policy: fail loudly. The audit chain captures which
    // sample tripped which stage, which is the actual production value.
    errorStrategy = 'terminate'
}

// ---------------------------------------------------------------------------
// Profiles
// ---------------------------------------------------------------------------

profiles {

    standard {
        // Tools resolved from PATH. Hour-1 confirmed FastQC, HISAT2, samtools,
        // and subread/featureCounts are on PATH via bioconda base env. MultiQC
        // lives in a dedicated `multiqc` conda env (lesson L-phi); the MULTIQC
        // process invokes it via `conda run -n multiqc`.
        process.executor = 'local'
    }

    lab {
        // Polish-Phase5 lab-node profile (chi-mac-m / chi-mac-p). Substrate
        // endpoints are exported by scripts/run_lab.sh before invoking nextflow.
        process.executor = 'local'
        process.cpus     = 4
        process.memory   = '4 GB'
    }
}

// ---------------------------------------------------------------------------
// Reports (lightweight; Nextflow writes them next to the work dir)
// ---------------------------------------------------------------------------

report {
    enabled   = true
    file      = "${params.results_dir}/_nextflow/execution-report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.results_dir}/_nextflow/execution-timeline.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.results_dir}/_nextflow/execution-trace.tsv"
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,start,duration,realtime,%cpu,peak_rss'
}
